# Dependencies / package manager output
node_modules/
.pnpm-store/

# TypeScript / Vite build outputs
packages/*/dist/
packages/*/tsconfig.tsbuildinfo
*.tsbuildinfo

# Electron Forge output
.vite/
out/
dist/

# Native (N-API / cmake-js) addon build artifacts
packages/native-core/build/
packages/native-core/prebuilds/
*.node

# Test output
playwright-report/
test-results/
.nyc_output/

# OS / editor junk
.DS_Store
Thumbs.db
*.swp

# Claude Code local (personal) settings — also ignored globally; listed for clarity
.claude/settings.local.json

# Bulky AI research artifacts — keep the distilled docs/ and the small synthesis,
# NOT the raw 808KB source copy or the multi-MB consult transcripts.
.planning/research/source-transcript.txt
.planning/research/*.out
.planning/research/*.utf8.txt

# Large archives
*.tgz

# Real TRE archives (local SWG install copies — never committed, see D-10)
packages/harness/fixtures-real/*.tre
packages/harness/fixtures-real/*.TRE
