{
  "name": "@swg/native-core",
  "version": "0.0.1",
  "description": "C++ Node-API addon — cmake-js build, prebuildify distribution",
  "main": "index.js",
  "scripts": {
    "build": "cmake-js build --generator \"Visual Studio 17 2022\" --platform x64",
    "rebuild": "cmake-js rebuild --generator \"Visual Studio 17 2022\" --platform x64",
    "prebuild": "node scripts/prebuild.js"
  },
  "dependencies": {
    "node-addon-api": "^8.8.0",
    "node-gyp-build": "^4"
  },
  "devDependencies": {
    "@electron/rebuild": "^4",
    "cmake-js": "^8",
    "prebuildify": "^6"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "prebuilds"
  ],
  "cmake-js": {
    "generator": "Visual Studio 17 2022",
    "platform": "x64"
  }
}
